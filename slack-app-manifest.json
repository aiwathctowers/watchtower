{
  "display_information": {
    "name": "Watchtower",
    "description": "Local Slack workspace intelligence tool",
    "long_description": "Watchtower syncs your Slack workspace into a local SQLite database and provides an AI-powered interface for analysis. It fetches channels, users, messages, and threads, stores them locally with full-text search, and lets you ask natural-language questions about your workspace via Claude. All data stays on your machine.",
